{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "framework": "vite",
      "buildCommand": "npm run build",
      "outputDirectory": "dist",
      "installCommand": "npm install"
    },
    "backend": {
      "root": "backend",
      "buildCommand": "npm run build",
      "startCommand": "node dist/index.js",
      "installCommand": "npm install"
    }
  }
}
